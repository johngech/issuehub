# ──────────────────────────────────────────────
# Environment variables for local development
# Copy to .env and fill in values
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=issuehub

# Server
DATABASE_URL=postgresql://postgres:changeme@postgres:5432/issuehub?schema=public
BETTER_AUTH_SECRET=generate-a-secure-random-string-here
BETTER_AUTH_URL=http://localhost:4000
TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
PORT=4000
NODE_ENV=development

# Client
VITE_API_URL=http://localhost:4000
